<style>
.report-container { font-family: 'Helvetica', 'Arial', sans-serif; }
.header { text-align: center; border-bottom: 2px solid #333; margin-bottom: 30px; }

.summary-grid { display: block; margin-bottom: 30px; }
.card { display: inline-block; width: 45%; padding: 10px; border: 1px solid #eee; text-align: center; }

.value { font-size: 20px; font-weight: bold; }
.positive { color: #2e7d32; }
.negative { color: #c62828; }

.progress-container {
  background-color: #f5f5f5;
  border-radius: 10px;
  height: 25px;
  width: 100%;
  border: 1px solid #ddd;
  margin-top: 10px;
}

.progress-bar {
  background-color: #2196f3;
  height: 25px;
  border-radius: 10px;
}

.over-limit { background-color: #f44336; }

.items-table { width: 100%; border-collapse: collapse; margin-top: 20px; }
.items-table th { background-color: #f8f9fa; border-bottom: 2px solid #dee2e6; padding: 10px; text-align: left; }
.items-table td { padding: 8px; border-bottom: 1px solid #eee; }

.report-container {
  -webkit-print-color-adjust: exact; /* Força as cores de fundo no PDF */
  print-color-adjust: exact;
}

/* Garante que a tabela não quebre de forma estranha entre páginas */
.items-table tr {
  page-break-inside: avoid;
}

</style>

<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <style>
      body { font-family: sans-serif; font-size: 12px; color: #333; }
      .header { text-align: center; border-bottom: 2px solid #000; margin-bottom: 20px; }
      .table { width: 100%; border-collapse: collapse; }
      .table th, .table td { border: 1px solid #ddd; padding: 8px; text-align: left; }
      .progress-bar-container { background: #eee; width: 100%; height: 20px; border-radius: 10px; }
      .progress-fill { background: #4caf50; height: 100%; border-radius: 10px; }
      .over-limit { background: #f44336; }
    </style>
  </head>
  <body>
    <%= yield %>
  </body>
</html>
