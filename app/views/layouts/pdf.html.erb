<style>
:root {
  --primary: #2c3e50;
  --income: #2e7d32;
  --income-light: #e8f5e9;
  --expense: #c62828;
  --forecast: #1565c0;
  --gray-light: #f8f9fa;
  --border: #dee2e6;
}

body {
  font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  color: #333;
  line-height: 1.4;
  margin: 0;
  padding: 0;
}

.report-container {
  padding: 20px;
  -webkit-print-color-adjust: exact;
  print-color-adjust: exact;
}

.header {
  text-align: center;
  border-bottom: 3px solid var(--primary);
  margin-bottom: 30px;
  padding-bottom: 10px;
}

/* Layout em Grid */
.dashboard-grid {
  display: flex;
  justify-content: space-between;
  gap: 20px;
  margin-bottom: 30px;
}

.column {
  width: 48%;
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 15px;
  background-color: #fff;
  box-sizing: border-box;
}

.forecast-bg {
  background-color: #f0f7ff;
  border-color: #c0d8ff;
}

.column-title {
  font-size: 14px;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-top: 0;
  color: var(--primary);
  border-bottom: 1px solid var(--border);
  padding-bottom: 8px;
  margin-bottom: 15px;
}

/* Cards */
.summary-card {
  margin-bottom: 12px;
  padding: 10px;
  background: var(--gray-light);
  border-radius: 6px;
}

.summary-card h4 { margin: 0; font-size: 11px; color: #666; text-transform: uppercase; }
.value { font-size: 18px; font-weight: bold; display: block; }
.positive { color: var(--income); }
.negative { color: var(--expense); }

/* Progress Bars */
.progress-container, .chart-bar {
  background-color: #eee;
  border-radius: 10px;
  height: 12px;
  width: 100%;
  overflow: hidden;
  margin: 8px 0;
}

.progress-bar, .spent-fill {
  background-color: var(--forecast);
  height: 100%;
}
.over-limit { background-color: var(--expense) !important; }
.spent-fill { background-color: var(--forecast); }

/* Alertas */
.alert-card { background-color: #fff3cd !important; border: 2px solid #ffc107 !important; }
.alert-text { color: #856404 !important; }

/* Tabela */
.items-table {
  width: 100%;
  border-collapse: collapse;
  margin-top: 15px;
  font-size: 11px;
  table-layout: auto;
}

.items-table th {
  background-color: var(--primary);
  color: white;
  padding: 10px;
  text-align: left;
}

.items-table td { padding: 8px; border-bottom: 1px solid var(--border); }

/* Cores das Linhas */
.items-table tr.entrada { background-color: var(--income-light) !important; }
.items-table tr.entrada td { color: #1b5e20 !important; }
.items-table tr:nth-child(even):not(.entrada) { background-color: #fafafa; }

/* Coluna de Valor (Sem quebra) */
.valor-celula {
  text-align: right;
  font-weight: bold;
  white-space: nowrap !important;
  width: 110px;
}

.badge {
  padding: 2px 6px;
  border-radius: 4px;
  font-size: 10px;
  background: #eee;
}
.entrada .badge { background-color: var(--income); color: white; }

@media print {
  .report-container { -webkit-print-color-adjust: exact; }
}
</style>

<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <title>Relatório Financeiro</title>
  </head>
  <body>
    <%= yield %>
  </body>
</html>
